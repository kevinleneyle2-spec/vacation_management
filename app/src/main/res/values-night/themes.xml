<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MVIApp" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Un blanc crème (nuance d'orange très pâle) -->
        <item name="windowSplashScreenBackground">@color/dark_pure</item>

        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>

        <item name="android:statusBarColor">@color/dark_pure</item>
        <item name="android:navigationBarColor">@color/dark_pure</item>

        <!-- Force les icônes en noir sur le fond clair -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- INTERDIT au système de forcer le mode sombre sur cet écran -->
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>

        <item name="postSplashScreenTheme">@style/Theme.MVIApp</item>
    </style>
</resources>
